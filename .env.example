# Database Credentials
SEND_DB_PASSWORD=your_database_password

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Backend Auth Configuration
APP_AUTH_SUPABASE_ISSUER_URI=https://your-project-id.supabase.co/auth/v1
APP_AUTH_SUPABASE_JWK_SET_URI=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
APP_AUTH_SUPABASE_JWT_SECRET=your_jwt_secret
APP_AUTH_SUPABASE_AUDIENCE=authenticated

# Other Config
APP_LECTURES_PROGRESS_COOKIE_SECRET=local_cookie_secret_for_testing
SERVER_PORT=8080
DATABASE_BOOTSTRAP_DATA_DIRECTORY=../data
