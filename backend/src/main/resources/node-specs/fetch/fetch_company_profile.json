    {
      "name": "field",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "company_name",
      "options": [
        "company_name",
        "industry_id",
        "isin",
        "fiscal_year_end_month",
        "number_employees",
        "business_summary",
        "market",
        "cik",
        "main_currency"
      ],
      "readableOptions": [
        "Company Name",
        "Industry ID",
        "ISIN",
        "Fiscal Year End Month",
        "Number of Employees",
        "Business Summary",
        "Market",
        "CIK",
        "Main Currency"
      ]
    }
  ],
  "executorKey": "fetch_company_profile"
}
