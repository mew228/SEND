{
  "nodeType": "fetch_fundamentals",
  "set": "fetch",
  "displayName": "Fetch Fundamentals",
  "description": "Fetches a high-signal fundamentals field for a configured ticker and report date.",
  "theme": "market",
  "inputs": [],
  "outputs": [
    {
      "index": 0,
      "name": "value",
      "arity": "ONE",
      "valueType": "NumVal"
    }
  ],
  "dataFields": [
    {
      "name": "ticker",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "AAPL"
    },
    {
      "name": "field",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "revenue",
      "options": [
        "revenue",
        "net_income",
        "shares_basic",
        "shares_diluted",
        "cash_and_st_investments",
        "total_current_assets",
        "total_assets",
        "total_current_liabilities",
        "total_liabilities",
        "total_equity",
        "net_cash_operating_activities",
        "net_cash_investing_activities",
        "net_cash_financing_activities",
        "net_change_cash"
      ],
      "readableOptions": [
        "Revenue",
        "Net Income",
        "Shares Basic",
        "Shares Diluted",
        "Cash and Short-Term Investments",
        "Total Current Assets",
        "Total Assets",
        "Total Current Liabilities",
        "Total Liabilities",
        "Total Equity",
        "Net Cash Operating Activities",
        "Net Cash Investing Activities",
        "Net Cash Financing Activities",
        "Net Change in Cash"
      ]
    },
    {
      "name": "dateBindingMode",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "simulation_day",
      "options": [
        "simulation_day",
        "simulation_day_offset",
        "explicit_date"
      ],
      "readableOptions": [
        "Simulation Day",
        "Simulation Day Offset",
        "Set Date"
      ]
    },
    {
      "name": "dayOffset",
      "valueType": "NumVal",
      "required": false,
      "defaultValue": 0,
      "visibleWhen": {
        "field": "dateBindingMode",
        "values": ["simulation_day_offset"]
      }
    },
    {
      "name": "reportDate",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "2020-04-30",
      "visibleWhen": {
        "field": "dateBindingMode",
        "values": ["explicit_date"]
      }
    }
  ],
  "executorKey": "fetch_fundamentals"
}
